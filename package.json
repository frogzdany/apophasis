{
  "name": "lucy-blob",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome check src",
    "lint:fix": "biome check --write src",
    "format": "biome format --write src",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:tools": "vitest run --config vitest.tools.config.ts",
    "validate:ui": "bun run scripts/validate-ui.ts",
    "server": "bun run server/index.ts",
    "dev:all": "bun run --silent server & bun run --silent dev"
  },
  "dependencies": {
    "@a2ui/react": "^0.9.1",
    "@anthropic-ai/sdk": "^0.95.1",
    "@google-cloud/storage": "^7.18.0",
