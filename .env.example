# Copy this file to .env.local and fill in the values you have.
# WARNING: VITE_-prefixed vars ship to the browser. Don't deploy this app
# publicly without proxying these calls through a backend.

# === Required ===
# Gemini Live API key — get one at https://aistudio.google.com/apikey
VITE_GEMINI_API_KEY=AIzaSyAtaqpkV7GwWB8a_SvwfYDn1J-SDTuSWeU

# === Optional providers (add as you go) ===

# YouTube Data API v3 — Google Cloud project with the API enabled +
# unrestricted (or HTTP-referrer-restricted) API key.
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
VITE_YOUTUBE_API_KEY=AIzaSyBqYoqoG0rhb4Es02a3fR7gzswDa9ff_F8

# === Server-side search keys ===
# These are read by the Bun proxy in server/searchProxy.ts. Browser code
# never sees them — it calls /api/search/<provider> instead. Do NOT add a
# VITE_ prefix to any of these.

# Brave Search API — https://api.search.brave.com/app/keys
BRAVE_API_KEY=
# Tavily Search API — https://app.tavily.com/home
TAVILY_API_KEY=
# Exa neural search — https://dashboard.exa.ai/api-keys
EXA_API_KEY=
# SerpApi (Google Books, Maps, Shopping engines) — https://serpapi.com/manage-api-key
SERPAPI_KEY=

# === Deprecated ===
# Was used by the old src/lib/search/providers/web.ts. The new web provider
# fans out across Brave / Tavily / Exa via /api/search/web instead. Kept
# here so older branches don't break on a missing var.
VITE_GOOGLE_SEARCH_API_KEY=
VITE_GOOGLE_SEARCH_CX=

# === Azure OpenAI — drawing interpretation (vision + search intent) ===
# portal.azure.com > your Azure OpenAI resource > Keys and Endpoint
# Deployment name = the name you gave when deploying gpt-4o in Azure AI Studio.
AZURE_OPENAI_ENDPOINT=https://icfoundry2pry.cognitiveservices.azure.com/openai/deployments/gpt-4o/chat/completions?api-version=2025-01-01-preview
AZURE_OPENAI_API_KEY=8sZbTt2Hhzmx7KCXwbv6B3qox0kOlFcfuVWpvqHMOAUqvWZMabN9JQQJ99CEACHYHv6XJ3w3AAAAACOGXxsa
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-12-01-preview

# === Future / unused right now ===
# Spotify Client Credentials (used by a server proxy if/when we add it).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

