# Copy this file to .env.local and fill in the values you have.
# WARNING: VITE_-prefixed vars ship to the browser. Don't deploy this app
# publicly without proxying these calls through a backend.

# === Required ===
#
# Server-side Gemini API key. The backend mints short-lived ephemeral
# tokens for the browser and never ships this value. Required for
# `bun run dev:all` (the dev server's /api/gemini-token endpoint reads
# it) and for production. https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
# Browser-side fallback for local dev only. Vite tree-shakes this out of
# production bundles; in dev it's the fallback when the token endpoint
# isn't running yet.
VITE_GEMINI_API_KEY=

# === Optional server config ===
#
# Override the Live model the ephemeral token is locked to. Defaults to
# gemini-3.1-flash-live-preview if unset. Set this when testing a new
# Live model variant.
GEMINI_LIVE_MODEL=
#
# Comma-separated list of origins allowed to hit /api/* on the Bun
# server. Defaults to localhost variants in dev. Set to your Cloud Run
# URL in prod (or leave to lock down to same-origin only).
ALLOWED_ORIGINS=

# === Server-side search keys ===
# These are read by the Bun proxy in server/searchProxy.ts. Browser code
# never sees them — it calls /api/search/<provider> instead. Do NOT add a
# VITE_ prefix to any of these.

# Brave Search API — https://api.search.brave.com/app/keys
# Powers /api/search/web (fan-out arm) AND /api/search/products (image
# search for the morph animation).
BRAVE_API_KEY=
# Tavily Search API — https://app.tavily.com/home
TAVILY_API_KEY=
# Exa neural search — https://dashboard.exa.ai/api-keys
EXA_API_KEY=
# SerpApi (Google Maps engine + books fallback) —
# https://serpapi.com/manage-api-key
SERPAPI_KEY=
# Google Books API v1 (volumes.list) — Google Cloud project with the
# Books API enabled. Primary backend for /api/search/books.
# https://console.cloud.google.com/apis/library/books.googleapis.com
GOOGLE_BOOKS_API_KEY=
# Google Places API (New) — server-side. Powers the
# /api/search/places_google, /api/search/places_nearby and
# /api/search/place_details routes (separate from the SerpApi-backed
# /api/search/places). Enable the "Places API (New)" in your Google
# Cloud project and create an API key restricted to that API.
# https://console.cloud.google.com/apis/library/places.googleapis.com
GOOGLE_PLACES_API_KEY=
# YouTube Data API v3 — Google Cloud project with the API enabled.
# Server-side only (used to live in the browser bundle as
# VITE_YOUTUBE_API_KEY; lifted to /api/search/video so the key never
# ships to clients).
# https://console.cloud.google.com/apis/library/youtube.googleapis.com
YOUTUBE_API_KEY=

# === Deprecated ===
# VITE_YOUTUBE_API_KEY: used to ship in the browser bundle; replaced by
# server-side YOUTUBE_API_KEY above. Kept here so older branches still
# parse without error.
VITE_YOUTUBE_API_KEY=
# VITE_GOOGLE_SEARCH_API_KEY / _CX: used by the old web provider. The
# new /api/search/web fans out across Brave / Tavily / Exa instead.
VITE_GOOGLE_SEARCH_API_KEY=
VITE_GOOGLE_SEARCH_CX=

# === Future / unused right now ===
# Spotify Client Credentials (used by a server proxy if/when we add it).
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
